# Files where supabase.from() is allowed in client (usually self tables)
AG_SUPABASE_CLIENT_ALLOW_FILES_REGEX='^src/hooks/useAuth\.tsx$'

# 0 = WARN (default), 1 = FAIL if supabase.from() appears outside allowlist
AG_FAIL_ON_SUPABASE_FROM_OUTSIDE_ALLOWLIST=0

# Offline module directory where Dexie writes are allowed
AG_OFFLINE_WRITE_ALLOWED_DIR_REGEX='^src/lib/offline/'

# Extra excludes for ripgrep (comma-separated)
AG_RG_EXCLUDE_GLOBS='!**/node_modules/**,!**/.git/**,!**/dist/**,!**/build/**'
